# Copy to `.env` (gitignored — CLAUDE.md rule 9). Qwen2.5-14B is UNGATED, so a
# HuggingFace token is NOT required for the download; HF_TOKEN only avoids rate
# limits. Set it as a Kaggle/Colab SECRET on the T4, never in code.
HF_TOKEN=your_hf_read_token_here

# Optional — ONLY for the API-cost reference numbers in the economic analysis.
# OPENAI_API_KEY=your_openai_key_here
# GOOGLE_API_KEY=your_free_gemini_key_here

# Kaggle credentials are NOT here — they live in ~/.kaggle/kaggle.json (outside
# the repo). Never commit kaggle.json.
